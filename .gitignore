.vscode/
.idea/

# Logs and core dumps
*.log
core.*

# Vendored reference trees — local only; not shipped with the repo.
# tools/build-musl.sh extracts references/musl-1.2.5.tar.gz locally.
references/

# musl build artifacts — NEVER track these.
# A stale config.mak (e.g., from macOS ARM) silently builds ARM musl
# on x86 servers, producing broken userspace binaries.
kernel/*_bin.c
kernel/*_blob.c
.init_stamp_*

# User-space built binaries — NEVER track these.
# The stale-binary catastrophe of 2026-03-28 was caused by git-tracked
# vigil/vigictl binaries surviving make clean and git checkout.
# Each user/bin/<name>/Makefile builds <name> (or <name>.elf) in-place.
user/bin/bastion/bastion
user/bin/cat/cat
user/bin/chmod/chmod
user/bin/chown/chown
user/bin/chronos/chronos
user/bin/clear/clear
user/bin/cp/cp
user/bin/dhcp/dhcp
user/bin/echo/echo
user/bin/false/false
user/bin/grep/grep
user/bin/gui-installer/gui-installer
user/bin/httpd/httpd
user/bin/installer/installer
user/bin/ln/ln
user/bin/login/login.elf
user/bin/ls/ls
user/bin/lumen/lumen
user/bin/mkdir/mkdir
user/bin/mv/mv
user/bin/nettest/nettest
user/bin/polltest/polltest
user/bin/pwd/pwd
user/bin/readlink/readlink
user/bin/reboot/reboot
user/bin/rm/rm
user/bin/rune
user/bin/shell/shell
user/bin/shutdown/shutdown
user/bin/sort/sort
user/bin/stsh/stsh
user/bin/touch/touch
user/bin/true/true
user/bin/uname/uname
user/bin/vigictl/vigictl
user/bin/vigil/vigil
user/bin/wc/wc
user/bin/whoami/whoami
tests/target/

# Test artifacts — screendumps change with every UI tweak and are
# regenerated by the test suite. Keep .gitkeep to preserve the dir.
tests/screenshots/*.ppm
tests/screenshots/*.png
